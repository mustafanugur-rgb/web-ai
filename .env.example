# Kopyalayın: .env olarak kaydedin ve değerleri doldurun. Bu dosyada GERÇEK anahtar tutmayın.

# PayTR (https://www.paytr.com paneli)
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=

# 1 = test, 0 = canlı ödeme
PAYTR_TEST_MODE=1

# Site kök URL (ödeme sonrası yönlendirme)
BASE_URL=https://www.example.com

# CSRF imzası — production’da uzun rastgele bir dize
CSRF_SECRET=change-me-to-a-long-random-string

PORT=3001

# AI satış asistanı (sales-agent-api)
# START_SALES_AGENT=0
# SALES_AGENT_URL=http://127.0.0.1:8000
# OpenAI: sales-agent-api/.env içinde (sales-agent-api/.env.example)

# SMTP — teklif / acil destek e-postası (isteğe bağlı)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=

ACIL_DESTEK_EMAIL=
# DEMO_TEKLIF_EMAIL=

# Telegram lead bildirimi (isteğe bağlı)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Twilio WhatsApp (isteğe bağlı)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=
# TWILIO_WHATSAPP_TO=

# OpenAI — asıl kullanım sales-agent-api/.env üzerinden
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4.1
# OPENAI_TEMPERATURE=0.7
