# Bu klasörde: copy .env.example .env  (satış asistanı API çalışma dizini sales-agent-api)
# https://platform.openai.com/api-keys — anahtarı repoya veya ekran görüntüsüne koymayın
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4.1
OPENAI_TEMPERATURE=0.7

# Lead bildirimi (isteğe bağlı) — @BotFather token + sizin chat_id
# Canlıda platform ortam değişkeni olarak da verilir (Railway/Render/Fly).
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Twilio WhatsApp bildirimi (isteğe bağlı; aynı lead metni)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+1...
# TWILIO_WHATSAPP_TO=whatsapp:+90...
